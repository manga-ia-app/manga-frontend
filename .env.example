# manga-frontend — environment variables
# Copy to .env.local (gitignored) for local dev

# API URL (.NET backend)
NEXT_PUBLIC_API_URL=http://localhost:5100/api

# AI Service (Python/LangGraph). One URL serves both HTTP (health,
# /ai/chat, etc.) and WebSocket — the WS client transforms
# http[s]:// → ws[s]:// at runtime.
NEXT_PUBLIC_AI_URL=http://localhost:5200

# Chat limits
NEXT_PUBLIC_CHAT_HISTORY_LIMIT=50
NEXT_PUBLIC_CHAT_RATE_LIMIT=10
